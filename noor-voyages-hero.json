  "content": [
    {
      "id": "nvhero01",
      "elType": "section",
      "settings": { "layout": "full_width", "gap": "no", "structure": "10", "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true } },
      "elements": [
        {
          "id": "nvhrcol1",
          "elType": "column",
          "settings": { "_column_size": 100, "_inline_size": null },
          "elements": [
            {
              "id": "nvhrhtml1",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class='nvhero'><style>@import url('https://api.fontshare.com/v2/css?f[]=clash-display@600,700&f[]=satoshi@400,500,700&f[]=caveat-brush@400&display=swap');.nvhero{--pk:#FF4FA3;--tl:#14B8A6;--cl:#FF8A5B;--yl:#FFCE4E;--cr:#FFF6EC;--ik:#0E1B2C;--fd:'Clash Display',system-ui,sans-serif;--fb:'Satoshi',system-ui,sans-serif;--fh:'Caveat Brush',cursive;position:relative;overflow:hidden;font-family:var(--fb);color:var(--ik);background:var(--cr)}.nvhero *{box-sizing:border-box}.nvhero a{text-decoration:none}.nvhero .bg{position:absolute;inset:-10%;z-index:0;background:radial-gradient(540px 380px at 12% 12%,#ff4fa329,transparent 62%),radial-gradient(560px 420px at 88% 20%,#14b8a629,transparent 60%),radial-gradient(440px 360px at 68% 96%,#ffce4e26,transparent 60%);animation:nvdrift 16s ease-in-out infinite alternate}@keyframes nvdrift{to{transform:scale(1.08) translateY(-12px)}}.nvhero .wrap{position:relative;z-index:3;max-width:1200px;margin:0 auto;padding:64px 24px 78px}.nvhero .hg{display:grid;grid-template-columns:1.1fr .9fr;gap:48px;align-items:center}.nvhero .pill{display:inline-flex;align-items:center;gap:9px;border:2px solid var(--ik);border-radius:999px;background:#fff;padding:8px 16px;font-weight:700;font-size:12.5px;letter-spacing:.1em;text-transform:uppercase;box-shadow:3px 3px 0 var(--ik);opacity:0;animation:nvrise .7s .1s both}.nvhero .pill .dot{width:9px;height:9px;border-radius:9px;background:var(--tl);box-shadow:0 0 0 0 #14b8a699;animation:nvpulse 2.2s infinite}@keyframes nvpulse{0%{box-shadow:0 0 0 0 #14b8a699}70%{box-shadow:0 0 0 10px #14b8a600}100%{box-shadow:0 0 0 0 #14b8a600}}.nvhero h1{font-size:clamp(50px,8vw,108px);letter-spacing:-.03em;line-height:.95;margin:22px 0 18px}.nvhero h1 .w{display:inline-block;opacity:0;transform:translateY(40px);animation:nvword .9s both}.nvhero h1 .w1{animation-delay:.15s}.nvhero h1 .w2{animation-delay:.27s}.nvhero h1 .w3{animation-delay:.39s}.nvhero .hand{font-family:var(--fh);color:var(--pk);font-weight:400}@keyframes nvword{to{opacity:1;transform:none}}.nvhero .sub{font-size:18px;color:#0e1b2cbb;max-width:480px;opacity:0;animation:nvrise .8s .5s both}.nvhero .ctas{display:flex;gap:14px;flex-wrap:wrap;margin:26px 0 40px;opacity:0;animation:nvrise .8s .62s both}.nvhero .btn{display:inline-flex;align-items:center;gap:8px;border:2px solid var(--ik);border-radius:999px;padding:15px 24px;font-family:var(--fd);font-weight:600;font-size:15px;box-shadow:4px 4px 0 var(--ik);background:var(--cr);transition:transform .18s,box-shadow .18s}.nvhero .btn:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--ik)}.nvhero .btn:active{transform:translate(2px,2px);box-shadow:0 0 0 var(--ik)}.nvhero .btn.pk{background:var(--pk);color:#fff}.nvhero .btn.gh{box-shadow:none}.nvhero .btn.gh:hover{background:var(--ik);color:var(--cr);transform:none}.nvhero .stats{display:flex;gap:36px;flex-wrap:wrap;opacity:0;animation:nvrise .8s .74s both}.nvhero .stt .n{font-family:var(--fd);font-weight:600;font-size:38px;line-height:1}.nvhero .stt .n i{font-style:normal;color:var(--pk)}.nvhero .stt .l{font-size:13.5px;color:#0e1b2c88;margin-top:5px}.nvhero .visual{position:relative;opacity:0;animation:nvrise .9s .35s both}.nvhero .postcard{position:relative;border:2px solid var(--ik);border-radius:28px;overflow:hidden;background:#fff;box-shadow:10px 10px 0 var(--ik);transform:rotate(2.5deg);animation:nvfloat 7s ease-in-out infinite}@keyframes nvfloat{0%,100%{transform:rotate(2.5deg) translateY(0)}50%{transform:rotate(2.5deg) translateY(-14px)}}.nvhero .postcard img{width:100%;display:block;aspect-ratio:4/3.5;object-fit:cover}.nvhero .stamp{position:absolute;top:14px;right:14px;z-index:4;width:62px;height:62px;border-radius:10px;background:var(--yl);border:2px solid var(--ik);display:flex;align-items:center;justify-content:center;text-align:center;font-family:var(--fd);font-weight:600;font-size:12px;line-height:1.1;transform:rotate(7deg);box-shadow:2px 2px 0 var(--ik)}.nvhero .badge{position:absolute;z-index:5;border:2px solid var(--ik);border-radius:999px;background:#fff;padding:10px 16px;font-family:var(--fd);font-weight:600;font-size:13.5px;box-shadow:4px 4px 0 var(--ik);white-space:nowrap;display:inline-flex;align-items:center;gap:8px;animation:nvbob 5s ease-in-out infinite}.nvhero .badge.b1{top:-18px;left:-24px;background:#CFF5EE;animation-delay:.2s}.nvhero .badge.b2{bottom:34px;right:-22px;background:#FFD6E8;animation-delay:.9s}@keyframes nvbob{0%,100%{transform:translateY(0) rotate(-2deg)}50%{transform:translateY(-12px) rotate(2deg)}}.nvhero .chip{position:absolute;left:-30px;bottom:-26px;z-index:5;width:96px;height:96px;border-radius:20px;border:2px solid var(--ik);background-size:cover;background-position:center;box-shadow:5px 5px 0 var(--ik);animation:nvbob 6s ease-in-out infinite;animation-delay:.5s}.nvhero .sun{position:absolute;top:10%;right:5%;z-index:1;width:74px;height:74px;animation:nvspin 26s linear infinite;opacity:.9}@keyframes nvspin{to{transform:rotate(360deg)}}.nvhero .arc{position:absolute;left:-2%;top:14%;width:min(440px,40vw);z-index:1;pointer-events:none;opacity:0;animation:nvrise 1s .8s both}@keyframes nvrise{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}@media(max-width:1020px){.nvhero .hg{grid-template-columns:1fr}.nvhero .visual{max-width:460px}.nvhero .arc{display:none}}@media(prefers-reduced-motion:reduce){.nvhero *{animation:none!important;opacity:1!important;transform:none!important}.nvhero .postcard{transform:rotate(2.5deg)!important}}</style><div class='bg'></div><svg class='sun' viewBox='0 0 100 100' fill='none' stroke='#FF8A5B' stroke-width='3' stroke-linecap='round'><circle cx='50' cy='50' r='18'/><path d='M50 10v12M50 78v12M10 50h12M78 50h12M22 22l8 8M70 70l8 8M78 22l-8 8M30 70l-8 8'/></svg><svg class='arc' viewBox='0 0 440 200' fill='none'><path d='M12 178 C 120 50, 320 50, 420 26' stroke='#0E1B2C' stroke-width='2.5' stroke-dasharray='3 12' stroke-linecap='round'/><circle cx='12' cy='178' r='7' fill='#14B8A6' stroke='#0E1B2C' stroke-width='2'/><g transform='translate(412 16) rotate(26)'><path d='M16 9 8 7 6 3 4 4l1 4-4 1 0 2 4 1-1 4 2 1 2-4 8-2a1.6 1.6 0 0 0 0-3z' fill='#FF4FA3' stroke='#0E1B2C' stroke-width='1.6' stroke-linejoin='round'/></g></svg><div class='wrap'><div class='hg'><div class='copy'><span class='pill'><span class='dot'></span><span data-en='Est. 2025 - Montreal' data-fr='Fonde en 2025 - Montreal'>Est. 2025 - Montreal</span></span><h1><span class='w w1' data-en='Pack' data-fr='Bagages'>Pack</span> <span class='w w2' data-en='light.' data-fr='legers.'>light.</span> <span class='w w3' data-en='Dream' data-fr='Reves'>Dream</span> <span class='w w3 hand' data-en='loud.' data-fr='immenses.'>loud.</span></h1><p class='sub' data-en='Sun-soaked beach escapes, spiritual pilgrimages, and city breaks, stitched together by humans who actually answer the phone.' data-fr='Des sejours plage, des pelerinages et des escapades urbaines, cousus main par des agents qui repondent vraiment au telephone.'>Sun-soaked beach escapes, spiritual pilgrimages, and city breaks, stitched together by humans who actually answer the phone.</p><div class='ctas'><a class='btn pk' href='/contact/' data-en='Plan my trip' data-fr='Planifier mon voyage'>Plan my trip</a><a class='btn gh' href='/packages/' data-en='Browse packages' data-fr='Voir les forfaits'>Browse packages</a></div><div class='stats'><div class='stt'><div class='n'><span class='count' data-to='42'>0</span></div><div class='l' data-en='destinations on tap' data-fr='destinations au menu'>destinations on tap</div></div><div class='stt'><div class='n'><span class='count' data-to='3.2' data-dec='1'>0</span><i>k</i></div><div class='l' data-en='happy voyagers' data-fr='voyageurs ravis'>happy voyagers</div></div><div class='stt'><div class='n'>24<i>/</i>7</div><div class='l' data-en='human support' data-fr='support humain'>human support</div></div></div></div><div class='visual'><div class='badge b1'>✈ <span data-en='Next departure: YUL to CUN' data-fr='Prochain depart : YUL a CUN'>Next departure: YUL to CUN</span></div><div class='postcard'><span class='stamp'>EST 2025</span><img src='https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-hero.jpg' alt='Tropical lagoon at golden hour'></div><div class='badge b2' data-en='3.2k happy voyagers' data-fr='3,2k voyageurs ravis'>3.2k happy voyagers</div><div class='chip' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-villa.jpg)'></div></div></div></div><script>(function(){var h=document.querySelector('.nvhero');if(!h)return;var red=window.matchMedia('(prefers-reduced-motion:reduce)').matches;function ap(l){h.querySelectorAll('[data-en]').forEach(function(s){var v=s.getAttribute('data-'+l.toLowerCase());if(v!=null)s.textContent=v;});}var cur='EN';try{cur=(localStorage.getItem('noor-lang')||'EN').toUpperCase();}catch(e){}if(cur==='FR')ap('FR');window.addEventListener('storage',function(e){if(e.key==='noor-lang')ap((e.newValue||'EN').toUpperCase());});document.addEventListener('click',function(e){if(e.target.closest('.lang,[data-nv-lang]')){setTimeout(function(){try{ap((localStorage.getItem('noor-lang')||'EN').toUpperCase());}catch(x){}},30);}});function run(el){var to=parseFloat(el.getAttribute('data-to'));var dec=parseInt(el.getAttribute('data-dec')||'0',10);if(red){el.textContent=to.toFixed(dec);return;}var st=null;function step(t){if(!st)st=t;var p=Math.min(1,(t-st)/1500);var e=1-Math.pow(1-p,3);el.textContent=(e*to).toFixed(dec);if(p<1)requestAnimationFrame(step);}requestAnimationFrame(step);}var seen=false;function go(){if(seen)return;seen=true;h.querySelectorAll('.count').forEach(run);}if('IntersectionObserver'in window){var io=new IntersectionObserver(function(en){en.forEach(function(x){if(x.isIntersecting)go();});},{threshold:.3});io.observe(h);}else{go();}})();</script></section>"
              }
            }
          ]
        }
      ]
    }
  ],
  "page_settings": []
}
