                "html": "<section class='nvpk'><style>@import url('https://api.fontshare.com/v2/css?f[]=clash-display@600,700&f[]=satoshi@400,500,700&f[]=caveat-brush@400&display=swap');.nvpk{--pk:#FF4FA3;--tl:#14B8A6;--cl:#FF8A5B;--yl:#FFCE4E;--cr:#FFF6EC;--ik:#0E1B2C;--fd:'Clash Display',system-ui,sans-serif;--fb:'Satoshi',system-ui,sans-serif;--fh:'Caveat Brush',cursive;font-family:var(--fb);color:var(--ik);background:var(--cr);padding:80px 0}.nvpk *{box-sizing:border-box}.nvpk a{text-decoration:none}.nvpk .wrap{max-width:1200px;margin:0 auto;padding:0 24px}.nvpk .ey{display:inline-flex;align-items:center;gap:8px;font-weight:700;font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--pk)}.nvpk .ey::before{content:'';width:24px;height:2px;background:var(--pk)}.nvpk h2{font-family:var(--fd);font-weight:600;font-size:clamp(32px,5vw,64px);letter-spacing:-.02em;margin:14px 0 8px;max-width:760px}.nvpk .hand{font-family:var(--fh);color:var(--pk);font-weight:400}.nvpk .ss{color:#0e1b2cbb;margin-bottom:34px;max-width:560px}.nvpk .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}.nvpk .card{position:relative;display:flex;flex-direction:column;border:2px solid var(--ik);border-radius:22px;background:#fff;overflow:hidden;box-shadow:6px 6px 0 var(--c,var(--ik));opacity:0;transform:translateY(28px);transition:opacity .6s cubic-bezier(.2,.8,.2,1),transform .6s cubic-bezier(.2,.8,.2,1),box-shadow .3s}.nvpk.in .card{opacity:1;transform:none}.nvpk.in .card:nth-child(2){transition-delay:.07s}.nvpk.in .card:nth-child(3){transition-delay:.14s}.nvpk.in .card:nth-child(4){transition-delay:.21s}.nvpk.in .card:nth-child(5){transition-delay:.28s}.nvpk.in .card:nth-child(6){transition-delay:.35s}.nvpk .card:hover{box-shadow:10px 12px 0 var(--c,var(--ik))}.nvpk .pic{height:188px;background-size:cover;background-position:center;border-bottom:2px solid var(--ik);position:relative;transition:transform .7s cubic-bezier(.2,.8,.2,1)}.nvpk .card:hover .pic{transform:scale(1.06)}.nvpk .tag{position:absolute;top:13px;left:13px;border:2px solid var(--ik);border-radius:999px;padding:5px 13px;font-weight:700;font-size:11.5px;letter-spacing:.1em;text-transform:uppercase;background:var(--c,var(--yl));color:var(--tg,#fff);box-shadow:2.5px 2.5px 0 var(--ik)}.nvpk .deal{position:absolute;top:13px;right:13px;border:2px solid var(--ik);border-radius:999px;padding:5px 12px;font-family:var(--fh);font-size:16px;background:var(--pk);color:#fff;transform:rotate(3deg);box-shadow:2.5px 2.5px 0 var(--ik)}.nvpk .b{padding:20px 22px 22px;display:flex;flex-direction:column;flex:1}.nvpk .b h3{font-family:var(--fd);font-weight:600;font-size:22px;line-height:1.1}.nvpk .meta{display:flex;gap:14px;margin-top:9px;font-size:13.5px;color:#0e1b2c88;flex-wrap:wrap}.nvpk .row{display:flex;align-items:flex-end;justify-content:space-between;margin-top:18px;gap:10px}.nvpk .was{font-size:13.5px;color:#0e1b2c88;text-decoration:line-through}.nvpk .now{font-family:var(--fd);font-weight:600;font-size:27px;letter-spacing:-.02em}.nvpk .pp{font-size:12.5px;color:#0e1b2c88}.nvpk .book{border:2px solid var(--ik);border-radius:999px;padding:11px 18px;font-family:var(--fd);font-weight:600;font-size:14px;background:var(--cr);box-shadow:3px 3px 0 var(--ik);transition:transform .18s,box-shadow .18s,background .2s,color .2s}.nvpk .book:hover{background:var(--ik);color:var(--cr);transform:translate(-2px,-2px);box-shadow:5px 5px 0 var(--pk)}.nvpk .foot{display:flex;justify-content:center;margin-top:50px}.nvpk .all{display:inline-flex;align-items:center;gap:8px;border:2px solid var(--ik);border-radius:999px;padding:15px 26px;font-family:var(--fd);font-weight:600;font-size:15px;background:var(--ik);color:var(--cr);box-shadow:4px 4px 0 var(--pk);transition:transform .18s,box-shadow .18s}.nvpk .all:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--pk)}@media(max-width:980px){.nvpk .grid{grid-template-columns:1fr 1fr}}@media(max-width:640px){.nvpk .grid{grid-template-columns:1fr}}@media(prefers-reduced-motion:reduce){.nvpk .card{opacity:1!important;transform:none!important}}</style><div class='wrap'><span class='ey' data-en='This month s picks' data-fr='Selection du mois'>This month s picks</span><h2><span data-en='Six trips our ' data-fr='Six voyages que notre '>Six trips our </span><span class='hand' data-en='team' data-fr='equipe'>team</span><span data-en=' would actually book.' data-fr=' reserverait pour elle-meme.'> would actually book.</span></h2><p class='ss' data-en='Curated monthly. Prices per person, taxes in, flights from Montreal.' data-fr='Renouveles chaque mois. Prix par personne, taxes incluses, vols au depart de Montreal.'>Curated monthly. Prices per person, taxes in, flights from Montreal.</p><div class='grid'><article class='card' style='--c:#14B8A6'><a class='pic' href='/trip-cancun/' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-beach.jpg)'><span class='tag' style='--c:#14B8A6;--tg:#fff' data-en='Beach' data-fr='Plage'>Beach</span><span class='deal' data-en='deal!' data-fr='aubaine!'>deal!</span></a><div class='b'><h3 data-en='Cancun - All Inclusive' data-fr='Cancun - Tout inclus'>Cancun - All Inclusive</h3><div class='meta'><span>7 nights</span><span>YUL → CUN</span></div><div class='row'><div><div class='was'>$1,340</div><div class='now'>$1,149</div><div class='pp' data-en='per person' data-fr='par personne'>per person</div></div><a class='book' href='/trip-cancun/' data-en='Reserve' data-fr='Reserver'>Reserve</a></div></div></article><article class='card' style='--c:#FFCE4E'><a class='pic' href='/contact/' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-mosque.jpg)'><span class='tag' style='--c:#FFCE4E;--tg:#0E1B2C' data-en='Pilgrimage' data-fr='Pelerinage'>Pilgrimage</span></a><div class='b'><h3 data-en='Umrah - Ramadan 2027' data-fr='Omra - Ramadan 2027'>Umrah - Ramadan 2027</h3><div class='meta'><span>12 nights</span><span>YUL → JED</span></div><div class='row'><div><div class='now'>$3,890</div><div class='pp' data-en='per person' data-fr='par personne'>per person</div></div><a class='book' href='/contact/' data-en='Reserve' data-fr='Reserver'>Reserve</a></div></div></article><article class='card' style='--c:#FF8A5B'><a class='pic' href='/trip-marrakech/' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-kasbah.jpg)'><span class='tag' style='--c:#FF8A5B;--tg:#fff' data-en='Culture' data-fr='Culture'>Culture</span><span class='deal' data-en='deal!' data-fr='aubaine!'>deal!</span></a><div class='b'><h3>Marrakech + Sahara</h3><div class='meta'><span>10 nights</span><span>YUL → RAK</span></div><div class='row'><div><div class='was'>$2,480</div><div class='now'>$2,240</div><div class='pp' data-en='per person' data-fr='par personne'>per person</div></div><a class='book' href='/trip-marrakech/' data-en='Reserve' data-fr='Reserver'>Reserve</a></div></div></article><article class='card' style='--c:#FF4FA3'><a class='pic' href='/contact/' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-city.jpg)'><span class='tag' style='--c:#FF4FA3;--tg:#fff' data-en='City' data-fr='Ville'>City</span></a><div class='b'><h3 data-en='Paris long weekend' data-fr='Paris long week-end'>Paris long weekend</h3><div class='meta'><span>4 nights</span><span>YUL → CDG</span></div><div class='row'><div><div class='now'>$1,390</div><div class='pp' data-en='per person' data-fr='par personne'>per person</div></div><a class='book' href='/contact/' data-en='Reserve' data-fr='Reserver'>Reserve</a></div></div></article><article class='card' style='--c:#14B8A6'><a class='pic' href='/trip-bali/' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-torii.jpg)'><span class='tag' style='--c:#14B8A6;--tg:#fff' data-en='Asia' data-fr='Asie'>Asia</span><span class='deal' data-en='deal!' data-fr='aubaine!'>deal!</span></a><div class='b'><h3>Bali - Ubud + Seminyak</h3><div class='meta'><span>11 nights</span><span>YUL → DPS</span></div><div class='row'><div><div class='was'>$2,920</div><div class='now'>$2,690</div><div class='pp' data-en='per person' data-fr='par personne'>per person</div></div><a class='book' href='/trip-bali/' data-en='Reserve' data-fr='Reserver'>Reserve</a></div></div></article><article class='card' style='--c:#FF4FA3'><a class='pic' href='/trip-santorini/' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-villa.jpg)'><span class='tag' style='--c:#FF4FA3;--tg:#fff' data-en='Honeymoon' data-fr='Lune de miel'>Honeymoon</span></a><div class='b'><h3 data-en='Santorini Honeymoon' data-fr='Santorin Lune de miel'>Santorini Honeymoon</h3><div class='meta'><span>8 nights</span><span>YUL → JTR</span></div><div class='row'><div><div class='now'>$3,450</div><div class='pp' data-en='per person' data-fr='par personne'>per person</div></div><a class='book' href='/trip-santorini/' data-en='Reserve' data-fr='Reserver'>Reserve</a></div></div></article></div><div class='foot'><a class='all' href='/packages/' data-en='See all 42 packages' data-fr='Voir les 42 forfaits'>See all 42 packages</a></div></div><script>(function(){var p=document.querySelector('.nvpk');if(!p)return;function ap(l){p.querySelectorAll('[data-en]').forEach(function(s){var v=s.getAttribute('data-'+l.toLowerCase());if(v!=null)s.textContent=v;});}var cur='EN';try{cur=(localStorage.getItem('noor-lang')||'EN').toUpperCase();}catch(e){}if(cur==='FR')ap('FR');window.addEventListener('storage',function(e){if(e.key==='noor-lang')ap((e.newValue||'EN').toUpperCase());});document.addEventListener('click',function(e){if(e.target.closest('.lang,[data-nv-lang]')){setTimeout(function(){try{ap((localStorage.getItem('noor-lang')||'EN').toUpperCase());}catch(x){}},30);}});if('IntersectionObserver'in window){var io=new IntersectionObserver(function(en){en.forEach(function(x){if(x.isIntersecting){p.classList.add('in');io.disconnect();}});},{threshold:.12});io.observe(p);}else{p.classList.add('in');}})();</script></section>"
