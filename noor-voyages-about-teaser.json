                "html": "<section class='nvab'><style>@import url('https://api.fontshare.com/v2/css?f[]=clash-display@600,700&f[]=satoshi@400,500,700&f[]=caveat-brush@400&display=swap');.nvab{--pk:#FF4FA3;--pks:#FFD6E8;--tl:#14B8A6;--tls:#CFF5EE;--cl:#FF8A5B;--yl:#FFCE4E;--cr:#FFF6EC;--ik:#0E1B2C;--fd:'Clash Display',system-ui,sans-serif;--fb:'Satoshi',system-ui,sans-serif;--fh:'Caveat Brush',cursive;--e:cubic-bezier(.2,.8,.2,1);font-family:var(--fb);color:var(--ik);background:var(--cr);padding:40px 0 110px}.nvab *{box-sizing:border-box}.nvab .wrap{max-width:1200px;margin:0 auto;padding:0 24px}.nvab .panel{position:relative;border:2px solid var(--ik);border-radius:28px;background:var(--tls);box-shadow:8px 8px 0 var(--tl);padding:clamp(34px,5vw,64px);display:grid;grid-template-columns:1.2fr .8fr;gap:48px;align-items:center;overflow:hidden;opacity:0;transform:translateY(26px);transition:opacity .7s var(--e),transform .7s var(--e)}.nvab.in .panel{opacity:1;transform:none}.nvab .ey{display:inline-flex;align-items:center;gap:8px;font-weight:700;font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--pk)}.nvab .ey::before{content:'';width:24px;height:2px;background:var(--pk)}.nvab h2{font-family:var(--fd);font-weight:600;font-size:clamp(34px,4.4vw,54px);letter-spacing:-.02em;line-height:1.02;margin-top:16px}.nvab .hand{font-family:var(--fh);color:var(--pk);font-weight:400}.nvab .body{margin-top:20px;color:#0e1b2cb8;font-size:17.5px}.nvab .bul{display:grid;gap:13px;position:relative;z-index:2}.nvab .b{display:flex;align-items:center;gap:13px;background:#fff;border:2px solid var(--ik);border-radius:14px;padding:14px 17px;font-weight:500;font-size:15.5px;box-shadow:3px 3px 0 var(--ik);transition:transform .25s var(--e),box-shadow .25s var(--e)}.nvab .b:hover{transform:translate(-2px,-2px);box-shadow:5px 5px 0 var(--ik)}.nvab .b .ic{width:30px;height:30px;border-radius:99px;flex:none;border:2px solid var(--ik);display:flex;align-items:center;justify-content:center}.nvab .b .ic svg{width:14px;height:14px}.nvab .doodle{position:absolute;right:-30px;top:-36px;width:170px;opacity:.5;transform:rotate(12deg);pointer-events:none;animation:nvspn 26s linear infinite}@keyframes nvspn{to{transform:rotate(372deg)}}@media(max-width:900px){.nvab .panel{grid-template-columns:1fr}.nvab .doodle{display:none}}@media(prefers-reduced-motion:reduce){.nvab .panel{opacity:1!important;transform:none!important}.nvab .doodle{animation:none}}</style><div class='wrap'><div class='panel'><svg class='doodle' viewBox='0 0 100 100' fill='none' stroke='#0E1B2C' stroke-width='1.6'><circle cx='50' cy='50' r='18'/><g stroke-linecap='round'><path d='M50 14v10M50 76v10M14 50h10M76 50h10M25 25l7 7M68 68l7 7M75 25l-7 7M32 68l-7 7'/></g></svg><div><span class='ey' data-en='About Noor Voyages' data-fr='A propos de Noor Voyages'>About Noor Voyages</span><h2><span data-en='A small ' data-fr='Petite agence '>A small </span><span class='hand'>Montreal</span><span data-en=' agency. Big little black book.' data-fr=' montrealaise. Grand carnet d adresses.'> agency. Big little black book.</span></h2><p class='body' data-en='Noor Voyages opened its door on Rue Jarry in 2025 with one rule: every trip gets a human. A bilingual team who do not upsell, do not disappear after you pay, and answer on the first ring - 450-600-1616.' data-fr='Noor Voyages a ouvert sur la rue Jarry en 2025 avec une regle : chaque voyage a un humain. Une equipe bilingue qui ne fait pas d upsell, ne disparait pas apres le paiement, et repond a la premiere sonnerie - 450-600-1616.'>Noor Voyages opened its door on Rue Jarry in 2025 with one rule: every trip gets a human. A bilingual team who do not upsell, do not disappear after you pay, and answer on the first ring - 450-600-1616.</p></div><div class='bul'><div class='b'><span class='ic' style='background:#FFD6E8'><svg viewBox='0 0 24 24' fill='none' stroke='#0E1B2C' stroke-width='2.6' stroke-linecap='round' stroke-linejoin='round'><path d='M20 6 9 17l-5-5'/></svg></span><span data-en='IATA-accredited partner network' data-fr='Reseau de partenaires accredites IATA'>IATA-accredited partner network</span></div><div class='b'><span class='ic' style='background:#CFF5EE'><svg viewBox='0 0 24 24' fill='none' stroke='#0E1B2C' stroke-width='2.6' stroke-linecap='round' stroke-linejoin='round'><path d='M20 6 9 17l-5-5'/></svg></span><span data-en='Bilingual service - English &amp; Francais' data-fr='Service bilingue - francais &amp; English'>Bilingual service - English &amp; Francais</span></div><div class='b'><span class='ic' style='background:#FFCE4E'><svg viewBox='0 0 24 24' fill='none' stroke='#0E1B2C' stroke-width='2.6' stroke-linecap='round' stroke-linejoin='round'><path d='M20 6 9 17l-5-5'/></svg></span><span data-en='Halal-friendly itineraries on request' data-fr='Itineraires halal sur demande'>Halal-friendly itineraries on request</span></div><div class='b'><span class='ic' style='background:#FF8A5B'><svg viewBox='0 0 24 24' fill='none' stroke='#0E1B2C' stroke-width='2.6' stroke-linecap='round' stroke-linejoin='round'><path d='M20 6 9 17l-5-5'/></svg></span><span data-en='Transparent pricing, no hidden fees' data-fr='Tarifs transparents, sans frais caches'>Transparent pricing, no hidden fees</span></div></div></div></div><script>(function(){var a=document.querySelector('.nvab');if(!a)return;function ap(l){a.querySelectorAll('[data-en]').forEach(function(s){var v=s.getAttribute('data-'+l.toLowerCase());if(v!=null)s.textContent=v;});}var cur='EN';try{cur=(localStorage.getItem('noor-lang')||'EN').toUpperCase();}catch(e){}if(cur==='FR')ap('FR');window.addEventListener('storage',function(e){if(e.key==='noor-lang')ap((e.newValue||'EN').toUpperCase());});document.addEventListener('click',function(e){if(e.target.closest('.lang,[data-nv-lang]')){setTimeout(function(){try{ap((localStorage.getItem('noor-lang')||'EN').toUpperCase());}catch(x){}},30);}});if('IntersectionObserver'in window){var io=new IntersectionObserver(