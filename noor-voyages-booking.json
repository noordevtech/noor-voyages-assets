              "settings": {
                "html": "<section class='nvbk' id='book'><style>@import url('https://api.fontshare.com/v2/css?f[]=clash-display@600,700&f[]=satoshi@400,500,700&f[]=caveat-brush@400&display=swap');.nvbk{--pk:#FF4FA3;--pks:#FFD6E8;--tl:#14B8A6;--cl:#FF8A5B;--yl:#FFCE4E;--cr:#FFF6EC;--ik:#0E1B2C;--fd:'Clash Display',system-ui,sans-serif;--fb:'Satoshi',system-ui,sans-serif;--fh:'Caveat Brush',cursive;--e:cubic-bezier(.2,.8,.2,1);font-family:var(--fb);color:var(--ik);background:var(--cr);padding:80px 0 110px}.nvbk *{box-sizing:border-box}.nvbk a{text-decoration:none;color:inherit}.nvbk .wrap{max-width:1200px;margin:0 auto;padding:0 24px}.nvbk .grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:56px;align-items:start}.nvbk .ey{display:inline-flex;align-items:center;gap:8px;font-weight:700;font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--pk)}.nvbk .ey::before{content:'';width:24px;height:2px;background:var(--pk)}.nvbk h2{font-family:var(--fd);font-weight:600;font-size:clamp(36px,5vw,68px);letter-spacing:-.02em;line-height:.98;margin:16px 0}.nvbk .hand{font-family:var(--fh);color:var(--pk);font-weight:400}.nvbk .sub{font-size:18px;color:#0e1b2cb8;max-width:440px}.nvbk .promise{margin-top:34px;border:2px solid var(--ik);border-radius:22px;background:var(--pks);box-shadow:5px 5px 0 var(--pk);padding:24px;font-size:16px}.nvbk .promise .pn{font-family:var(--fh);font-size:23px;color:var(--pk);display:block;margin-bottom:6px}.nvbk .crows{margin-top:30px;display:grid;gap:10px}.nvbk .crows a{display:inline-flex;align-items:center;gap:12px;font-weight:500;font-size:16.5px;transition:color .2s}.nvbk .crows a:hover{color:var(--pk)}.nvbk .crows svg{width:17px;height:17px;color:var(--tl)}.nvbk .form{position:relative;border:2px solid var(--ik);border-radius:28px;background:#fff;box-shadow:8px 8px 0 var(--ik);padding:clamp(26px,4vw,44px);overflow:hidden}.nvbk .frow{display:grid;grid-template-columns:1fr 1fr;gap:18px}.nvbk .fld{margin-bottom:18px}.nvbk .fld label{display:block;font-size:11.5px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#0e1b2c88;margin:0 0 7px 4px}.nvbk .fld input,.nvbk .fld textarea{width:100%;border:2px solid var(--ik);border-radius:13px;background:var(--cr);padding:14px 15px;font:inherit;font-weight:500;color:var(--ik);outline:none;transition:transform .2s var(--e),box-shadow .2s var(--e),background .2s,border-color .2s}.nvbk .fld textarea{resize:vertical;min-height:100px}.nvbk .fld input:focus,.nvbk .fld textarea:focus{transform:translate(-2px,-2px);box-shadow:3px 3px 0 var(--ik);background:#fff}.nvbk .fld input.bad{border-color:#e23a3a;animation:nvsh .45s var(--e)}@keyframes nvsh{0%,100%{transform:translateX(0)}20%{transform:translateX(-7px)}40%{transform:translateX(6px)}60%{transform:translateX(-4px)}80%{transform:translateX(3px)}}.nvbk .chips{display:flex;flex-wrap:wrap;gap:9px;margin-bottom:22px}.nvbk .chip{border:2px solid var(--ik);border-radius:999px;padding:9px 16px;font-family:var(--fd);font-weight:600;font-size:14px;background:var(--cr);cursor:pointer;transition:background .2s,color .2s,transform .18s var(--e),box-shadow .18s var(--e)}.nvbk .chip:hover{transform:translate(-1px,-1px);box-shadow:2.5px 2.5px 0 var(--ik)}.nvbk .chip.on{background:var(--ik);color:var(--cr);box-shadow:2.5px 2.5px 0 var(--pk)}.nvbk .srow{display:flex;align-items:center;gap:18px;flex-wrap:wrap;margin-top:8px}.nvbk .btn{display:inline-flex;align-items:center;gap:10px;border:2px solid var(--ik);border-radius:999px;padding:15px 24px;font-family:var(--fd);font-weight:600;font-size:15px;background:var(--pk);color:#fff;box-shadow:4px 4px 0 var(--ik);cursor:pointer;transition:transform .18s var(--e),box-shadow .18s var(--e)}.nvbk .btn:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--ik)}.nvbk .btn svg{width:16px;height:16px}.nvbk .rea{font-size:13.5px;color:#0e1b2c88}.nvbk .sent{position:absolute;inset:0;z-index:5;background:var(--tl);color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:16px;padding:40px;clip-path:circle(0% at 50% 110%);transition:clip-path .8s var(--e);pointer-events:none}.nvbk .sent.show{clip-path:circle(150% at 50% 100%);pointer-events:auto}.nvbk .sent svg{width:74px;height:74px}.nvbk .sent h3{font-family:var(--fd);font-weight:600;font-size:30px;color:#fff}.nvbk .sent p{max-width:380px;font-size:16.5px;color:rgba(255,255,255,.92)}.nvbk .again{margin-top:8px;background:var(--cr);color:var(--ik);box-shadow:4px 4px 0 var(--ik)}@media(max-width:960px){.nvbk .grid{grid-template-columns:1fr}}@media(max-width:620px){.nvbk .frow{grid-template-columns:1fr}}</style><div class='wrap'><div class='grid'><div class='side'><span class='ey' data-en='Let us plan it' data-fr='On planifie'>Let us plan it</span><h2><span data-en='Tell us where you are ' data-fr='Dites-nous ou vous '>Tell us where you are </span><span class='hand' data-en='dreaming.' data-fr='revez.'>dreaming.</span></h2><p class='sub' data-en='We reply within 4 business hours with a proposal - no robo-forms, no commitment.' data-fr='On repond en moins de 4 heures ouvrables avec une proposition - pas de robot, pas d engagement.'>We reply within 4 business hours with a proposal - no robo-forms, no commitment.</p><div class='promise'><span class='pn' data-en='our promise -' data-fr='notre promesse -'>our promise -</span><span data-en='A real human reads every inquiry. No upsell, no hidden fees, no newsletter you did not ask for.' data-fr='Un vrai humain lit chaque demande. Pas d upsell, pas de frais caches, pas d infolettre non sollicitee.'>A real human reads every inquiry. No upsell, no hidden fees, no newsletter you did not ask for.</span></div><div class='crows'><a href='tel:4506001616'><svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z'/></svg>450-600-1616</a><a href='mailto:info@noorvoyages.ca'><svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='2' y='4' width='20' height='16' rx='2'/><path d='m22 7-10 6L2 7'/></svg>info@noorvoyages.ca</a></div></div><form class='form' novalidate><div class='frow'><div class='fld'><label data-en='Your name' data-fr='Votre nom'>Your name</label><input type='text' id='bk-name' required></div><div class='fld'><label data-en='Email' data-fr='Courriel'>Email</label><input type='email' id='bk-email' required></div></div><div class='frow'><div class='fld'><label data-en='Phone' data-fr='Telephone'>Phone</label><input type='tel'></div><div class='fld'><label data-en='Approx. dates' data-fr='Dates approximatives'>Approx. dates</label><input type='text'></div></div><div class='fld'><label data-en='Trip type' data-fr='Type de voyage'>Trip type</label><div class='chips' data-grp='trip'><button type='button' class='chip' data-en='Beach' data-fr='Plage'>Beach</button><button type='button' class='chip' data-en='Umrah' data-fr='Omra'>Umrah</button><button type='button' class='chip' data-en='Morocco' data-fr='Maroc'>Morocco</button><button type='button' class='chip' data-en='Europe' data-fr='Europe'>Europe</button><button type='button' class='chip' data-en='Honeymoon' data-fr='Lune de miel'>Honeymoon</button><button type='button' class='chip' data-en='Group tour' data-fr='Groupe'>Group tour</button><button type='button' class='chip' data-en='Asia' data-fr='Asie'>Asia</button><button type='button' class='chip' data-en='Surprise me' data-fr='Surprise'>Surprise me</button></div></div><div class='frow'><div class='fld'><label data-en='Destination (or vibe)' data-fr='Destination (ou ambiance)'>Destination (or vibe)</label><input type='text'></div><div class='fld'><label data-en='Travelers' data-fr='Voyageurs'>Travelers</label><input type='text'></div></div><div class='fld'><label data-en='Budget per person' data-fr='Budget par personne'>Budget per person</label><div class='chips' data-grp='budget'><button type='button' class='chip' data-en='Under $1,500' data-fr='Moins de 1 500 $'>Under $1,500</button><button type='button' class='chip'>$1,500 - $3,000</button><button type='button' class='chip'>$3,000 - $5,000</button><button type='button' class='chip'>$5,000+</button></div></div><div class='fld'><label data-en='Anything else we should know?' data-fr='Autre chose a savoir?'>Anything else we should know?</label><textarea></textarea></div><div class='srow'><button type='submit' class='btn'><svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='m22 2-7 20-4-9-9-4Z'/><path d='M22 2 11 13'/></svg><span data-en='Send my inquiry' data-fr='Envoyer ma demande'>Send my inquiry</span></button><span class='rea' data-en='We will never share your info.' data-fr='Vos infos restent chez nous.'>We will never share your info.</span></div><div class='sent'><svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><path d='m22 2-7 20-4-9-9-4Z'/><path d='M22 2 11 13'/></svg><h3 data-en='Merci! It is in good hands.' data-fr='Merci! C est entre bonnes mains.'>Merci! It is in good hands.</h3><p data-en='We have got it - an agent will be in touch within 4 business hours.' data-fr='On a tout recu - un agent vous ecrit dans les 4 heures ouvrables.'>We have got it - an agent will be in touch within 4 business hours.</p><button type='button' class='btn again' data-en='Send another inquiry' data-fr='Envoyer une autre demande'>Send another inquiry</button></div></form></div></div><script>(function(){var b=document.querySelector('.nvbk');if(!b)return;function ap(l){b.querySelectorAll('[data-en]').forEach(function(s){var v=s.getAttribute('data-'+l.toLowerCase());if(v!=null)s.textContent=v;});}var cur='EN';try{cur=(localStorage.getItem('noor-lang')||'EN').toUpperCase();}catch(e){}if(cur==='FR')ap('FR');window.addEventListener('storage',function(e){if(e.key==='noor-lang')ap((e.newValue||'EN').toUpperCase());});document.addEventListener('click',function(e){if(e.target.closest('.lang,[data-nv-lang]')){setTimeout(function(){try{ap((localStorage.getItem('noor-lang')||'EN').toUpperCase());}catch(x){}},30);}});b.querySelectorAll('.chips').forEach(function(grp){grp.querySelectorAll('.chip').forEach(function(c){c.addEventListener('click',function(){var on=c.classList.contains('on');grp.querySelectorAll('.chip').forEach(function(x){x.classList.remove('on');});if(!on)c.classList.add('on');});});});var form=b.querySelector('.form'),sent=b.querySelector('.sent');form.addEventListener('submit',function(e){e.preventDefault();var ok=true;[b.querySelector('#bk-name'),b.querySelector('#bk-email')].forEach(function(inp){var bad=!inp.value.trim()||(inp.type==='email'&&!/^\\S+@\\S+\\.\\S+$/.test(inp.value));if(bad){ok=false;inp.classList.remove('bad');void inp.offsetWidth;inp.classList.add('bad');setTimeout(function(){inp.classList.remove('bad');},1600);}});if(ok)sent.classList.add('show');});b.querySelector('.again').addEventListener('click',function(){sent.classList.remove('show');form.reset();b.querySelectorAll('.chip.on').forEach(function(c){c.classList.remove('on');});});})();</script></section>"
              }
            }
          ]
        }
      ]
    }
