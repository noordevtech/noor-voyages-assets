          "elements": [
            {
              "id": "nvtesh1",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class='nvtesti'><style>@import url('https://api.fontshare.com/v2/css?f[]=clash-display@600,700&f[]=satoshi@400,500,700&f[]=caveat-brush@400&display=swap');.nvtesti{--pk:#FF4FA3;--tl:#14B8A6;--cl:#FF8A5B;--yl:#FFCE4E;--cr:#FFF6EC;--ik:#0E1B2C;--fd:'Clash Display',system-ui,sans-serif;--fb:'Satoshi',system-ui,sans-serif;--fh:'Caveat Brush',cursive;font-family:var(--fb);color:var(--ik);background:var(--cr);padding:80px 0}.nvtesti *{box-sizing:border-box}.nvtesti .wrap{max-width:1200px;margin:0 auto;padding:0 24px}.nvtesti .ey{display:inline-flex;align-items:center;gap:8px;font-weight:700;font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--pk)}.nvtesti .ey::before{content:'';width:24px;height:2px;background:var(--pk)}.nvtesti h2{font-family:var(--fd);font-weight:600;font-size:clamp(32px,5vw,60px);letter-spacing:-.02em;margin:14px 0 34px}.nvtesti .hand{font-family:var(--fh);color:var(--pk);font-weight:400}.nvtesti .grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}.nvtesti .card{border:2px solid var(--ik);border-radius:22px;background:#fff;padding:28px;box-shadow:6px 6px 0 var(--ik);opacity:0;transform:translateY(26px);transition:opacity .6s cubic-bezier(.2,.8,.2,1),transform .6s cubic-bezier(.2,.8,.2,1)}.nvtesti.in .card{opacity:1;transform:none}.nvtesti.in .card:nth-child(2){transition-delay:.08s}.nvtesti.in .card:nth-child(3){transition-delay:.16s}.nvtesti.in .card:nth-child(4){transition-delay:.24s}.nvtesti .q{font-family:var(--fh);font-size:54px;line-height:.5;color:var(--pk);display:block;margin-bottom:14px}.nvtesti .txt{font-size:17px;line-height:1.6}.nvtesti .stars{color:var(--yl);margin-top:16px;letter-spacing:2px;font-size:16px}.nvtesti .who{display:flex;align-items:center;gap:14px;margin-top:20px}.nvtesti .av{width:46px;height:46px;border-radius:999px;border:2px solid var(--ik);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-weight:600;font-size:16px;color:#fff;flex:none}.nvtesti .name{font-family:var(--fd);font-weight:600;font-size:16px}.nvtesti .trip{font-size:13px;color:#0e1b2c88}@media(max-width:760px){.nvtesti .grid{grid-template-columns:1fr}}@media(prefers-reduced-motion:reduce){.nvtesti .card{opacity:1!important;transform:none!important}}</style><div class='wrap'><span class='ey' data-en='Kind words' data-fr='Mots gentils'>Kind words</span><h2><span data-en='Voyagers who came back ' data-fr='Des voyageurs revenus '>Voyagers who came back </span><span class='hand' data-en='grinning.' data-fr='souriants.'>grinning.</span></h2><div class='grid'><div class='card'><span class='q'>&ldquo;</span><p class='txt' data-en='Our mutawwif knew every shortcut around the Haram. We actually got to pray in peace instead of fighting crowds. Allah yjazihoum kheir.' data-fr='Notre mutawwif connaissait tous les raccourcis autour du Haram. On a vraiment pu prier en paix. Allah yjazihoum kheir.'>Our mutawwif knew every shortcut around the Haram. We actually got to pray in peace instead of fighting crowds. Allah yjazihoum kheir.</p><div class='stars'>★★★★★</div><div class='who'><div class='av' style='background:#FFCE4E;color:#0E1B2C'>L</div><div><div class='name'>Leila &amp; Karim B.</div><div class='trip' data-en='Umrah · March 2026' data-fr='Omra · mars 2026'>Umrah · March 2026</div></div></div></div><div class='card'><span class='q'>&ldquo;</span><p class='txt' data-en='Noor booked us into a room with a connecting door for the kids, on the quiet end of the resort. Nobody else caught that detail. Already rebooking for 2027.' data-fr='Noor nous a reserve une chambre avec porte communicante pour les enfants, au bout calme du complexe. Deja reserves pour 2027.'>Noor booked us into a room with a connecting door for the kids, on the quiet end of the resort. Nobody else caught that detail. Already rebooking for 2027.</p><div class='stars'>★★★★★</div><div class='who'><div class='av' style='background:#CFF5EE;color:#0E1B2C'>T</div><div><div class='name' data-en='The Tremblay family' data-fr='Famille Tremblay'>The Tremblay family</div><div class='trip' data-en='Cancun · February 2026' data-fr='Cancun · fevrier 2026'>Cancun · February 2026</div></div></div></div><div class='card'><span class='q'>&ldquo;</span><p class='txt' data-en='They built a two-week itinerary in 48 hours, talked us out of one hotel (rightly) and into another, and checked in halfway through. Felt like having a friend in the business.' data-fr='Itineraire de deux semaines bati en 48h, un hotel remplace (avec raison), suivi a mi-parcours. Comme avoir une amie dans le metier.'>They built a two-week itinerary in 48 hours, talked us out of one hotel (rightly) and into another, and checked in halfway through. Felt like having a friend in the business.</p><div class='stars'>★★★★★</div><div class='who'><div class='av' style='background:#FFD6E8;color:#0E1B2C'>S</div><div><div class='name'>Sophie L.</div><div class='trip' data-en='Santorini honeymoon · 2025' data-fr='Lune de miel Santorin · 2025'>Santorini honeymoon · 2025</div></div></div></div><div class='card'><span class='q'>&ldquo;</span><p class='txt' data-en='Small group, local riads, a guide who was also a historian. Not one hour felt touristy. Bien joue Noor.' data-fr='Petit groupe, riads locaux, guide historien. Pas une heure touristique. Bien joue Noor.'>Small group, local riads, a guide who was also a historian. Not one hour felt touristy. Bien joue Noor.</p><div class='stars'>★★★★★</div><div class='who'><div class='av' style='background:#FF8A5B;color:#fff'>M</div><div><div class='name'>Mehdi A.</div><div class='trip' data-en='Marrakech group · October 2025' data-fr='Marrakech groupe · octobre 2025'>Marrakech group · October 2025</div></div></div></div></div></div><script>(function(){var t=document.querySelector('.nvtesti');if(!t)return;function ap(l){t.querySelectorAll('[data-en]').forEach(function(s){var v=s.getAttribute('data-'+l.toLowerCase());if(v!=null)s.textContent=v;});}var cur='EN';try{cur=(localStorage.getItem('noor-lang')||'EN').toUpperCase();}catch(e){}if(cur==='FR')ap('FR');window.addEventListener('storage',function(e){if(e.key==='noor-lang')ap((e.newValue||'EN').toUpperCase());});document.addEventListener('click',function(e){if(e.target.closest('.lang,[data-nv-lang]')){setTimeout(function(){try{ap((localStorage.getItem('noor-lang')||'EN').toUpperCase());}catch(x){}},30);}});if('IntersectionObserver'in window){var io=new IntersectionObserver(function(en){en.forEach(function(x){if(x.isIntersecting){t.classList.add('in');io.disconnect();}});},{threshold:.12});io.observe(t);}else{t.classList.add('in');}})();</script></section>"
              }
            }
