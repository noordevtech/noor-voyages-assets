              "widgetType": "html",
              "settings": {
                "html": "<section class='nvhx'><style>@import url('https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&f[]=satoshi@300,400,500,700&f[]=caveat-brush@400&display=swap');.nvhx{--pk:#FF4FA3;--pks:#FFD6E8;--tl:#14B8A6;--tls:#CFF5EE;--cl:#FF8A5B;--yl:#FFCE4E;--cr:#FFF6EC;--ik:#0E1B2C;--fd:'Clash Display',system-ui,sans-serif;--fb:'Satoshi',system-ui,sans-serif;--fh:'Caveat Brush',cursive;position:relative;overflow:hidden;font-family:var(--fb);color:var(--ik);background:radial-gradient(900px 540px at 12% 8%,#ff4fa329,transparent 64%),radial-gradient(820px 560px at 88% 22%,#14b8a62b,transparent 62%),radial-gradient(640px 460px at 70% 92%,#ffce4e24,transparent 60%),var(--cr)}.nvhx *{box-sizing:border-box}.nvhx a{text-decoration:none;color:inherit}.nvhx #nvg-canvas{position:absolute;right:0;top:0;width:62%;height:100%;z-index:1;pointer-events:none}@media(max-width:1020px){.nvhx #nvg-canvas{opacity:.5}}.nvhx .wrap{position:relative;z-index:3;max-width:1280px;margin:0 auto;padding:54px 32px 70px}.nvhx .hg{display:grid;grid-template-columns:1.18fr .82fr;gap:48px;align-items:center}.nvhx .kick{display:inline-flex;align-items:center;gap:10px;border:2px solid var(--ik);border-radius:999px;background:#fff;padding:8px 16px;font-weight:700;font-size:12.5px;letter-spacing:.12em;text-transform:uppercase;box-shadow:3px 3px 0 var(--ik);opacity:0;animation:nvr .7s .1s both}.nvhx .kick .dot{width:9px;height:9px;border-radius:9px;background:var(--tl);animation:nvp 2.2s infinite}@keyframes nvp{0%{box-shadow:0 0 0 0 #14b8a699}70%{box-shadow:0 0 0 10px #14b8a600}100%{box-shadow:0 0 0 0 #14b8a600}}.nvhx h1{font-family:var(--fd);font-weight:600;font-size:clamp(56px,8.6vw,118px);line-height:.95;letter-spacing:-.025em;margin:26px 0 22px}.nvhx h1 .w{display:inline-block;opacity:0;transform:translateY(42px);animation:nvw .9s both}.nvhx h1 .w1{animation-delay:.12s}.nvhx h1 .w2{animation-delay:.24s}.nvhx h1 .w3{animation-delay:.36s}.nvhx h1 .w4{animation-delay:.48s}@keyframes nvw{to{opacity:1;transform:none}}.nvhx .hand{font-family:var(--fh);color:var(--pk);font-weight:400}.nvhx .sub{font-size:19px;color:#0e1b2cbb;max-width:520px;opacity:0;animation:nvr .8s .55s both}.nvhx .ctas{display:flex;gap:14px;flex-wrap:wrap;margin:30px 0 44px;opacity:0;animation:nvr .8s .67s both}.nvhx .btn{display:inline-flex;align-items:center;gap:10px;border:2px solid var(--ik);border-radius:999px;padding:15px 24px;font-family:var(--fd);font-weight:600;font-size:15px;box-shadow:4px 4px 0 var(--ik);background:var(--cr);transition:transform .18s,box-shadow .18s}.nvhx .btn:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--ik)}.nvhx .btn:active{transform:translate(2px,2px);box-shadow:0 0 0 var(--ik)}.nvhx .btn.pk{background:var(--pk);color:#fff}.nvhx .btn.gh{box-shadow:none}.nvhx .btn.gh:hover{background:var(--ik);color:var(--cr);transform:none}.nvhx .stats{display:flex;gap:38px;flex-wrap:wrap;opacity:0;animation:nvr .8s .79s both}.nvhx .stt .n{font-family:var(--fd);font-weight:600;font-size:38px;line-height:1}.nvhx .stt .n i{font-style:normal;color:var(--pk)}.nvhx .stt .l{font-size:14px;color:#0e1b2c88;margin-top:6px}.nvhx .visual{position:relative;opacity:0;animation:nvr .9s .35s both}.nvhx .postcard{position:relative;border:2px solid var(--ik);border-radius:28px;overflow:hidden;background:#fff;box-shadow:8px 8px 0 var(--ik);transform:rotate(2.5deg);animation:nvfl 7s ease-in-out infinite}@keyframes nvfl{0%,100%{transform:rotate(2.5deg) translateY(0)}50%{transform:rotate(2.5deg) translateY(-13px)}}.nvhx .postcard img{width:100%;display:block;aspect-ratio:4/3.1;object-fit:cover}.nvhx .stamp{position:absolute;top:14px;right:14px;z-index:4;width:64px;height:74px;background:var(--yl);border:2px solid var(--ik);border-radius:8px;display:flex;align-items:center;justify-content:center;text-align:center;font-family:var(--fh);font-size:15px;line-height:1.1;transform:rotate(6deg)}.nvhx .postmark{position:absolute;left:16px;bottom:14px;z-index:4;font-family:var(--fh);font-size:20px;color:#fff;text-shadow:1.5px 1.5px 0 var(--ik);transform:rotate(-3deg)}.nvhx .badge{position:absolute;z-index:5;border:2px solid var(--ik);border-radius:999px;background:#fff;padding:10px 18px;font-family:var(--fd);font-weight:600;font-size:14px;box-shadow:4px 4px 0 var(--ik);white-space:nowrap;display:inline-flex;align-items:center;gap:8px;animation:nvb 5s ease-in-out infinite}.nvhx .badge.f1{top:-18px;left:-26px;background:var(--tls);animation-delay:.2s}.nvhx .badge.f2{bottom:34px;right:-20px;background:var(--pks);animation-delay:.9s}.nvhx .badge.f3{bottom:-16px;left:10%;background:var(--yl);font-family:var(--fh);font-size:18px;font-weight:400;animation-delay:.5s}@keyframes nvb{0%,100%{transform:translateY(0) rotate(-2deg)}50%{transform:translateY(-12px) rotate(2deg)}}.nvhx .finder{position:relative;z-index:3;margin-top:56px;border:2px solid var(--ik);border-radius:28px;background:#fff;box-shadow:8px 8px 0 var(--tl);padding:22px;opacity:0;animation:nvr .8s .9s both}.nvhx .finder .ftl{position:absolute;top:-19px;left:26px;background:var(--yl);border:2px solid var(--ik);border-radius:999px;padding:6px 18px;font-family:var(--fh);font-size:21px;transform:rotate(-2deg)}.nvhx .fgrid{display:grid;grid-template-columns:repeat(4,1fr) auto;gap:12px;align-items:end}.nvhx .ff label{display:block;font-size:11.5px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#0e1b2c88;margin:0 0 7px 4px}.nvhx .ff .ctrl{display:flex;align-items:center;gap:10px;border:2px solid var(--ik);border-radius:14px;padding:13px 14px;background:var(--cr);transition:box-shadow .2s,transform .2s}.nvhx .ff .ctrl:focus-within{transform:translate(-2px,-2px);box-shadow:3px 3px 0 var(--ik);background:#fff}.nvhx .ff input{border:none;outline:none;background:transparent;font:inherit;font-weight:500;width:100%;color:var(--ik)}.nvhx .ff .ic{font-size:15px;color:var(--pk)}.nvhx .fbtn{display:inline-flex;align-items:center;justify-content:center;gap:8px;border:2px solid var(--ik);border-radius:999px;padding:15px 22px;font-family:var(--fd);font-weight:600;font-size:15px;background:var(--tl);color:#fff;box-shadow:4px 4px 0 var(--ik);transition:transform .18s,box-shadow .18s}.nvhx .fbtn:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--ik)}@keyframes nvr{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}@media(max-width:1020px){.nvhx .hg{grid-template-columns:1fr}.nvhx .visual{max-width:480px}}@media(max-width:980px){.nvhx .fgrid{grid-template-columns:1fr 1fr}}@media(max-width:560px){.nvhx .fgrid{grid-template-columns:1fr}}@media(prefers-reduced-motion:reduce){.nvhx *{animation:none!important;opacity:1!important;transform:none!important}.nvhx .postcard{transform:rotate(2.5deg)!important}}</style><canvas id='nvg-canvas'></canvas><div class='wrap'><div class='hg'><div class='copy'><span class='kick'><span class='dot'></span><span data-en='Est. 2025 - Montreal' data-fr='Fonde en 2025 - Montreal'>Est. 2025 - Montreal</span></span><h1><span class='w w1' data-en='Pack' data-fr='Bagages'>Pack</span> <span class='w w2' data-en='light.' data-fr='legers.'>light.</span> <span class='w w3' data-en='Dream' data-fr='Reves'>Dream</span> <span class='w w4 hand' data-en='loud.' data-fr='immenses.'>loud.</span></h1><p class='sub' data-en='Noor Voyages crafts sun-soaked beach escapes, spiritual pilgrimages, and city breaks stitched together by humans who actually answer the phone.' data-fr='Noor Voyages concoit des sejours plage, des pelerinages et des escapades urbaines, cousus main par des agents qui repondent vraiment au telephone.'>Noor Voyages crafts sun-soaked beach escapes, spiritual pilgrimages, and city breaks stitched together by humans who actually answer the phone.</p><div class='ctas'><a class='btn pk' href='/contact/' data-en='Plan my trip' data-fr='Planifier mon voyage'>Plan my trip</a><a class='btn gh' href='/packages/' data-en='Browse packages' data-fr='Voir les forfaits'>Browse packages</a></div><div class='stats'><div class='stt'><div class='n'><span class='count' data-to='42'>0</span></div><div class='l' data-en='destinations on tap' data-fr='destinations au menu'>destinations on tap</div></div><div class='stt'><div class='n'><span class='count' data-to='3.2' data-dec='1'>0</span><i>k</i></div><div class='l' data-en='happy voyagers' data-fr='voyageurs ravis'>happy voyagers</div></div><div class='stt'><div class='n'>24<i>/</i>7</div><div class='l' data-en='human support' data-fr='support humain'>human support</div></div></div></div><div class='visual'><div class='badge f1'>✈ <span data-en='Next departure: YUL to CUN' data-fr='Prochain depart : YUL a CUN'>Next departure: YUL to CUN</span></div><div class='postcard'><span class='stamp'>EST 2025</span><img src='https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-hero.jpg' alt='Tropical lagoon at golden hour'><span class='postmark' data-en='wish you were here!' data-fr='on pense a vous!'>wish you were here!</span></div><div class='badge f2'>✓ <span data-en='3.2k happy voyagers' data-fr='3,2k voyageurs ravis'>3.2k happy voyagers</span></div><div class='badge f3'>Bonjour / Hello!</div></div></div><div class='finder'><div class='ftl' data-en='Where to next?' data-fr='On part ou?'>Where to next?</div><div class='fgrid'><div class='ff'><label data-en='Flying from' data-fr='Depart'>Flying from</label><div class='ctrl'><span class='ic'>✈</span><input type='text' value='Montreal (YUL)'></div></div><div class='ff'><label data-en='Going to' data-fr='Destination'>Going to</label><div class='ctrl'><span class='ic'>◎</span><input type='text' placeholder='Anywhere warm'></div></div><div class='ff'><label data-en='When' data-fr='Quand'>When</label><div class='ctrl'><span class='ic'>▦</span><input type='text' placeholder='Any week'></div></div><div class='ff'><label data-en='Travelers' data-fr='Voyageurs'>Travelers</label><div class='ctrl'><span class='ic'>◍</span><input type='text' placeholder='2 adults'></div></div><a class='fbtn' href='/packages/' data-en='Find trips' data-fr='Chercher'>Find trips</a></div></div></div><script src='https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js'></script><script>(function(){function init(){if(!window.THREE){return setTimeout(init,120);}var host=document.querySelector('.nvhx');if(!host)return;var canvas=host.querySelector('#nvg-canvas');if(!canvas)return;if(window.matchMedia('(prefers-reduced-motion:reduce)').matches)return;var T=window.THREE;var rnd=new T.WebGLRenderer({canvas:canvas,alpha:true,antialias:true});rnd.setPixelRatio(Math.min(window.devicePixelRatio,2));var scene=new T.Scene();var cam=new T.PerspectiveCamera(42,1,0.1,100);cam.position.set(0,0.2,7.2);var world=new T.Group();scene.add(world);var R=2.5,N=1100;var pos=new Float32Array(N*3),col=new Float32Array(N*3);var INK=new T.Color('#0E1B2C'),PK=new T.Color('#FF4FA3'),TL=new T.Color('#14B8A6'),CL=new T.Color('#FF8A5B');var pal=[INK,INK,INK,PK,TL,CL];for(var i=0;i<N;i++){var y=1-(i/(N-1))*2;var r=Math.sqrt(1-y*y);var th=i*2.39996323;pos[i*3]=Math.cos(th)*r*R;pos[i*3+1]=y*R;pos[i*3+2]=Math.sin(th)*r*R;var c=pal[i%6];col[i*3]=c.r;col[i*3+1]=c.g;col[i*3+2]=c.b;}var g=new T.BufferGeometry();g.setAttribute('position',new T.BufferAttribute(pos,3));g.setAttribute('color',new T.BufferAttribute(col,3));var pts=new T.Points(g,new T.PointsMaterial({size:0.05,vertexColors:true,transparent:true,opacity:0.55,sizeAttenuation:true}));world.add(pts);var wire=new T.Mesh(new T.SphereGeometry(R*0.99,22,14),new T.MeshBasicMaterial({color:INK,wireframe:true,transparent:true,opacity:0.05}));world.add(wire);function ll(lat,lng,rr){var phi=(90-lat)*Math.PI/180,theta=(lng+180)*Math.PI/180;return new T.Vector3(-rr*Math.sin(phi)*Math.cos(theta),rr*Math.cos(phi),rr*Math.sin(phi)*Math.sin(theta));}var YUL=[45.47,-73.74];var routes=[[21.04,-86.87,TL],[21.42,39.83,new T.Color('#FFCE4E')],[48.86,2.35,PK],[-8.65,115.22,TL],[36.39,25.46,PK],[4.17,73.51,CL]];var arcs=[];routes.forEach(function(rt,idx){var a=ll(YUL[0],YUL[1],R),b=ll(rt[0],rt[1],R);var d=a.distanceTo(b);var mid=a.clone().add(b).multiplyScalar(0.5).normalize().multiplyScalar(R+d*0.35);var cv=new T.QuadraticBezierCurve3(a,mid,b);var p=cv.getPoints(60);var lg=new T.BufferGeometry().setFromPoints(p);var lm=new T.LineBasicMaterial({color:rt[2],transparent:true,opacity:0.5});var ln=new T.Line(lg,lm);lg.setDrawRange(0,0);world.add(ln);arcs.push({geo:lg,off:idx*0.15,sp:0.085});});function size(){var w=host.clientWidth,h=host.clientHeight;rnd.setSize(w,h,false);cam.aspect=w/h;cam.updateProjectionMatrix();var wide=w>1020;world.position.set(wide?3.3:0,wide?-0.3:-3,wide?-1.1:-2.2);var s=wide?1:0.82;world.scale.set(s,s,s);}size();window.addEventListener('resize',size);var mx=0,my=0,tx=0,ty=0;window.addEventListener('pointermove',function(e){tx=(e.clientX/window.innerWidth-0.5)*2;ty=(e.clientY/window.innerHeight-0.5)*2;},{passive:true});var clock=new T.Clock();function tick(){requestAnimationFrame(tick);var t=clock.getElapsedTime();mx+=(tx-mx)*0.04;my+=(ty-my)*0.04;world.rotation.y=t*0.08+mx*0.18;world.rotation.x=-0.18+my*0.1;for(var k=0;k<arcs.length;k++){var ar=arcs[k];var cyc=((t*ar.sp)+ar.off)%1;var gr=Math.min(1,cyc/0.55);ar.geo.setDrawRange(0,Math.floor(gr*60)+1);}rnd.render(scene,cam);}tick();}init();})();</script><script>(function(){var h=document.querySelector('.nvhx');if(!h)return;var red=window.matchMedia('(prefers-reduced-motion:reduce)').matches;function ap(l){h.querySelectorAll('[data-en]').forEach(function(s){var v=s.getAttribute('data-'+l.toLowerCase());if(v!=null)s.textContent=v;});}var cur='EN';try{cur=(localStorage.getItem('noor-lang')||'EN').toUpperCase();}catch(e){}if(cur==='FR')ap('FR');window.addEventListener('storage',function(e){if(e.key==='noor-lang')ap((e.newValue||'EN').toUpperCase());});document.addEventListener('click',function(e){if(e.target.closest('.lang,[data-nv-lang]')){setTimeout(function(){try{ap((localStorage.getItem('noor-lang')||'EN').toUpperCase());}catch(x){}},30);}});function run(el){var to=parseFloat(el.getAttribute('data-to'));var dec=parseInt(el.getAttribute('data-dec')||'0',10);if(red){el.textContent=to.toFixed(dec);return;}var st=null;function step(t){if(!st)st=t;var p=Math.min(1,(t-st)/1500);var e=1-Math.pow(1-p,3);el.textContent=(e*to).toFixed(dec);if(p<1)requestAnimationFrame(step);}requestAnimationFrame(step);}var seen=false;function go(){if(seen)return;seen=true;h.querySelectorAll('.count').forEach(run);}if('IntersectionObserver'in window){var io=new IntersectionObserver(function(en){en.forEach(function(x){if(x.isIntersecting)go();});},{threshold:.25});io.observe(h);}else{go();}})();</script></section>"
              }
            }
          ]
        }
      ]
    }
