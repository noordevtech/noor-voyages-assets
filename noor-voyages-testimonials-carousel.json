  "content": [
    {
      "id": "nvtc01",
      "elType": "section",
      "settings": { "layout": "full_width", "gap": "no", "structure": "10", "padding": { "unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": true } },
      "elements": [
        {
          "id": "nvtcc1",
          "elType": "column",
          "settings": { "_column_size": 100, "_inline_size": null },
          "elements": [
            {
              "id": "nvtch1",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<section class='nvtc'><style>@import url('https://api.fontshare.com/v2/css?f[]=clash-display@600,700&f[]=satoshi@400,500,700&f[]=caveat-brush@400&display=swap');.nvtc{--pk:#FF4FA3;--pks:#FFD6E8;--tl:#14B8A6;--tls:#CFF5EE;--cl:#FF8A5B;--yl:#FFCE4E;--cr:#FFF6EC;--ik:#0E1B2C;--fd:'Clash Display',system-ui,sans-serif;--fb:'Satoshi',system-ui,sans-serif;--fh:'Caveat Brush',cursive;--e:cubic-bezier(.2,.8,.2,1);font-family:var(--fb);color:var(--ik);background:var(--cr);padding:80px 0;overflow:hidden}.nvtc *{box-sizing:border-box}.nvtc .wrap{max-width:1200px;margin:0 auto;padding:0 24px}.nvtc .ey{display:inline-flex;align-items:center;gap:8px;font-weight:700;font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--pk)}.nvtc .ey::before{content:'';width:24px;height:2px;background:var(--pk)}.nvtc h2{font-family:var(--fd);font-weight:600;font-size:clamp(32px,5vw,64px);letter-spacing:-.02em;margin:16px 0 40px}.nvtc .hand{font-family:var(--fh);color:var(--pk);font-weight:400}.nvtc .stage{position:relative;overflow:hidden}.nvtc .track{display:flex;gap:26px;cursor:grab;will-change:transform;transition:transform .75s var(--e)}.nvtc .track.grab{cursor:grabbing;transition:none}.nvtc .card{flex:none;width:min(480px,86vw);border:2px solid var(--ik);border-radius:22px;background:#fff;box-shadow:6px 6px 0 var(--ik);padding:30px;user-select:none}.nvtc .qm{font-family:var(--fh);font-size:64px;line-height:.6;color:var(--pk);display:block;margin-bottom:16px}.nvtc .q{font-size:17.5px;line-height:1.6}.nvtc .stars{color:var(--yl);margin-top:16px;letter-spacing:3px;font-size:17px}.nvtc .who{display:flex;align-items:center;gap:14px;margin-top:24px}.nvtc .av{width:48px;height:48px;border-radius:999px;border:2px solid var(--ik);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-weight:600;font-size:16px;flex:none}.nvtc .name{font-family:var(--fd);font-weight:600;font-size:16.5px}.nvtc .trip{font-size:13.5px;color:#0e1b2c88}.nvtc .nav{display:flex;gap:12px;margin-top:40px}.nvtc .nav button{width:52px;height:52px;border-radius:999px;border:2px solid var(--ik);background:var(--cr);display:flex;align-items:center;justify-content:center;box-shadow:3px 3px 0 var(--ik);cursor:pointer;transition:transform .18s var(--e),box-shadow .18s var(--e),background .2s,color .2s}.nvtc .nav button:hover{background:var(--pk);color:#fff;transform:translate(-2px,-2px);box-shadow:5px 5px 0 var(--ik)}.nvtc .nav button:active{transform:translate(2px,2px);box-shadow:0 0 0 var(--ik)}.nvtc .nav svg{width:18px;height:18px}@media(prefers-reduced-motion:reduce){.nvtc .track{transition:none}}</style><div class='wrap'><span class='ey' data-en='Kind words' data-fr='Mots gentils'>Kind words</span><h2><span data-en='Voyagers who came back ' data-fr='Des voyageurs revenus '>Voyagers who came back </span><span class='hand' data-en='grinning.' data-fr='souriants.'>grinning.</span></h2><div class='stage'><div class='track'><article class='card'><span class='qm'>&ldquo;</span><p class='q' data-en='Our mutawwif knew every shortcut around the Haram. We actually got to pray in peace instead of fighting crowds. Allah yjazihoum kheir.' data-fr='Notre mutawwif connaissait tous les raccourcis autour du Haram. On a vraiment pu prier en paix. Allah yjazihoum kheir.'>Our mutawwif knew every shortcut around the Haram. We actually got to pray in peace instead of fighting crowds. Allah yjazihoum kheir.</p><div class='stars'>★★★★★</div><div class='who'><div class='av' style='background:#FFCE4E'>L</div><div><div class='name'>Leila &amp; Karim B.</div><div class='trip' data-en='Umrah · March 2026' data-fr='Omra · mars 2026'>Umrah · March 2026</div></div></div></article><article class='card'><span class='qm'>&ldquo;</span><p class='q' data-en='Noor booked us into a room with a connecting door for the kids, on the quiet end of the resort. Nobody else caught that detail. Already rebooking for 2027.' data-fr='Noor nous a reserve une chambre avec porte communicante pour les enfants, au bout calme du complexe. Deja reserves pour 2027.'>Noor booked us into a room with a connecting door for the kids, on the quiet end of the resort. Nobody else caught that detail. Already rebooking for 2027.</p><div class='stars'>★★★★★</div><div class='who'><div class='av' style='background:#CFF5EE'>T</div><div><div class='name' data-en='The Tremblay family' data-fr='Famille Tremblay'>The Tremblay family</div><div class='trip' data-en='Cancun · February 2026' data-fr='Cancun · fevrier 2026'>Cancun · February 2026</div></div></div></article><article class='card'><span class='qm'>&ldquo;</span><p class='q' data-en='They built a two-week itinerary in 48 hours, talked us out of one hotel (rightly) and into another, and checked in halfway through. Felt like having a friend in the business.' data-fr='Itineraire de deux semaines bati en 48h, un hotel remplace (avec raison), suivi a mi-parcours. Comme avoir une amie dans le metier.'>They built a two-week itinerary in 48 hours, talked us out of one hotel (rightly) and into another, and checked in halfway through. Felt like having a friend in the business.</p><div class='stars'>★★★★★</div><div class='who'><div class='av' style='background:#FFD6E8'>S</div><div><div class='name'>Sophie L.</div><div class='trip' data-en='Santorini honeymoon · 2025' data-fr='Lune de miel Santorin · 2025'>Santorini honeymoon · 2025</div></div></div></article><article class='card'><span class='qm'>&ldquo;</span><p class='q' data-en='Small group, local riads, a guide who was also a historian. Not one hour felt touristy. Bien joue Noor.' data-fr='Petit groupe, riads locaux, guide historien. Pas une heure touristique. Bien joue Noor.'>Small group, local riads, a guide who was also a historian. Not one hour felt touristy. Bien joue Noor.</p><div class='stars'>★★★★★</div><div class='who'><div class='av' style='background:#FF8A5B;color:#fff'>M</div><div><div class='name'>Mehdi A.</div><div class='trip' data-en='Marrakech group · October 2025' data-fr='Marrakech groupe · octobre 2025'>Marrakech group · October 2025</div></div></div></article></div></div><div class='nav'><button class='prev' aria-label='Previous'><svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'><path d='M19 12H5M12 19l-7-7 7-7'/></svg></button><button class='next' aria-label='Next'><svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'><path d='M5 12h14M12 5l7 7-7 7'/></svg></button></div></div><script>(function(){var t=document.querySelector('.nvtc');if(!t)return;var red=window.matchMedia('(prefers-reduced-motion:reduce)').matches;function ap(l){t.querySelectorAll('[data-en]').forEach(function(s){var v=s.getAttribute('data-'+l.toLowerCase());if(v!=null)s.textContent=v;});}var cur='EN';try{cur=(localStorage.getItem('noor-lang')||'EN').toUpperCase();}catch(e){}if(cur==='FR')ap('FR');window.addEventListener('storage',function(e){if(e.key==='noor-lang')ap((e.newValue||'EN').toUpperCase());});document.addEventListener('click',function(e){if(e.target.closest('.lang,[data-nv-lang]')){setTimeout(function(){try{ap((localStorage.getItem('noor-lang')||'EN').toUpperCase());}catch(x){}},30);}});var stage=t.querySelector('.stage'),track=t.querySelector('.track');var idx=0,auto;function step(){var c=track.children[0];return c?c.getBoundingClientRect().width+26:300;}function maxI(){var vis=Math.max(1,Math.floor(stage.clientWidth/step()));return Math.max(0,track.children.length-vis);}function go(i,inst){idx=Math.max(0,Math.min(maxI(),i));var x=-idx*step();if(inst||red){track.style.transition='none';track.style.transform='translateX('+x+'px)';void track.offsetWidth;track.style.transition='';}else{track.style.transform='translateX('+x+'px)';}}t.querySelector('.prev').addEventListener('click',function(){go(idx-1);restart();});t.querySelector('.next').addEventListener('click',function(){go(idx>=maxI()?0:idx+1);restart();});function restart(){clearInterval(auto);if(!red)auto=setInterval(function(){go(idx>=maxI()?0:idx+1);},5200);}restart();window.addEventListener('resize',function(){go(idx,true);});var down=false,sx=0,base=0;track.addEventListener('pointerdown',function(e){down=true;sx=e.clientX;base=-idx*step();track.classList.add('grab');clearInterval(auto);try{track.setPointerCapture(e.pointerId);}catch(x){}});track.addEventListener('pointermove',function(e){if(!down)return;track.style.transform='translateX('+(base+(e.clientX-sx))+'px)';});function end(e){if(!down)return;down=false;track.classList.remove('grab');var d=e.clientX-sx;if(Math.abs(d)>60)go(idx+(d<0?1:-1));else go(idx);restart();}track.addEventListener('pointerup',end);track.addEventListener('pointercancel',end);})();</script></section>"
              }
            }
          ]
        }
      ]
    }
  ],
  "page_settings": []
}
