              "widgetType": "html",
              "settings": {
                "html": "<section class='nvtiles'><style>@import url('https://api.fontshare.com/v2/css?f[]=clash-display@600,700&f[]=satoshi@400,500,700&f[]=caveat-brush@400&display=swap');.nvtiles{--pk:#FF4FA3;--tl:#14B8A6;--cl:#FF8A5B;--yl:#FFCE4E;--cr:#FFF6EC;--ik:#0E1B2C;--fd:'Clash Display',system-ui,sans-serif;--fb:'Satoshi',system-ui,sans-serif;--fh:'Caveat Brush',cursive;font-family:var(--fb);color:var(--ik);background:var(--cr);padding:80px 0}.nvtiles *{box-sizing:border-box}.nvtiles a{text-decoration:none}.nvtiles .wrap{max-width:1200px;margin:0 auto;padding:0 24px}.nvtiles .ey{display:inline-flex;align-items:center;gap:8px;font-weight:700;font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--pk)}.nvtiles .ey::before{content:'';width:24px;height:2px;background:var(--pk)}.nvtiles h2{font-family:var(--fd);font-weight:600;font-size:clamp(32px,5vw,64px);letter-spacing:-.02em;margin:14px 0 8px}.nvtiles .hand{font-family:var(--fh);color:var(--pk);font-weight:400}.nvtiles .ss{color:#0e1b2cbb;margin-bottom:30px;max-width:560px}.nvtiles .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}.nvtiles .tile{position:relative;display:block;border:2px solid var(--ik);border-radius:18px;overflow:hidden;box-shadow:5px 5px 0 var(--c,var(--ik));opacity:0;transform:translateY(26px);transition:opacity .6s cubic-bezier(.2,.8,.2,1),transform .6s cubic-bezier(.2,.8,.2,1),box-shadow .3s}.nvtiles.in .tile{opacity:1;transform:none}.nvtiles.in .tile:nth-child(2){transition-delay:.06s}.nvtiles.in .tile:nth-child(3){transition-delay:.12s}.nvtiles.in .tile:nth-child(4){transition-delay:.18s}.nvtiles.in .tile:nth-child(5){transition-delay:.24s}.nvtiles.in .tile:nth-child(6){transition-delay:.3s}.nvtiles.in .tile:nth-child(7){transition-delay:.36s}.nvtiles.in .tile:nth-child(8){transition-delay:.42s}.nvtiles .tile:hover{box-shadow:9px 11px 0 var(--c,var(--ik))}.nvtiles .pic{height:160px;background-size:cover;background-position:center;transition:transform .7s cubic-bezier(.2,.8,.2,1)}.nvtiles .tile:hover .pic{transform:scale(1.09)}.nvtiles .lb{position:absolute;left:0;right:0;bottom:0;padding:13px 15px;color:#fff;font-family:var(--fd);font-weight:600;font-size:16px;background:linear-gradient(transparent,rgba(14,27,44,.78));z-index:2}.nvtiles .seeall{display:flex;align-items:center;justify-content:center;height:160px;font-size:46px;background:linear-gradient(135deg,#0E1B2C,#14B8A6)}@media(max-width:980px){.nvtiles .grid{grid-template-columns:1fr 1fr}}@media(max-width:520px){.nvtiles .grid{grid-template-columns:1fr}}@media(prefers-reduced-motion:reduce){.nvtiles .tile{opacity:1!important;transform:none!important}}</style><div class='wrap'><span class='ey' data-en='Where we go' data-fr='Ou on va'>Where we go</span><h2><span data-en='Seven ways to ' data-fr='Sept facons de '>Seven ways to </span><span class='hand' data-en='wander.' data-fr='vagabonder.'>wander.</span></h2><p class='ss' data-en='Seven loose categories, endless itineraries. Tell us the vibe and we build the week.' data-fr='Sept categories souples, d infinies possibilites. Dites-nous l ambiance et on batit la semaine.'>Seven loose categories, endless itineraries. Tell us the vibe and we build the week.</p><div class='grid'><a class='tile' href='/packages/' style='--c:#14B8A6'><div class='pic' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-beach.jpg)'></div><span class='lb' data-en='Beach &amp; Tropics' data-fr='Plage &amp; Tropiques'>Beach &amp; Tropics</span></a><a class='tile' href='/packages/' style='--c:#FFCE4E'><div class='pic' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-mosque.jpg)'></div><span class='lb' data-en='Hajj &amp; Umrah' data-fr='Hajj &amp; Omra'>Hajj &amp; Umrah</span></a><a class='tile' href='/packages/' style='--c:#FF8A5B'><div class='pic' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-kasbah.jpg)'></div><span class='lb' data-en='Morocco' data-fr='Maroc'>Morocco</span></a><a class='tile' href='/packages/' style='--c:#FF4FA3'><div class='pic' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-city.jpg)'></div><span class='lb' data-en='European Cities' data-fr='Villes europeennes'>European Cities</span></a><a class='tile' href='/packages/' style='--c:#FF4FA3'><div class='pic' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-villa.jpg)'></div><span class='lb' data-en='Honeymoons' data-fr='Lunes de miel'>Honeymoons</span></a><a class='tile' href='/packages/' style='--c:#FFCE4E'><div class='pic' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-bus.jpg)'></div><span class='lb' data-en='Group Tours' data-fr='Voyages de groupe'>Group Tours</span></a><a class='tile' href='/packages/' style='--c:#14B8A6'><div class='pic' style='background-image:url(https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-torii.jpg)'></div><span class='lb' data-en='Asia' data-fr='Asie'>Asia</span></a><a class='tile' href='/destinations/' style='--c:#0E1B2C'><div class='pic seeall'>🌍</div><span class='lb' data-en='See all' data-fr='Tout voir'>See all</span></a></div></div><script>(function(){var t=document.querySelector('.nvtiles');if(!t)return;function ap(l){t.querySelectorAll('[data-en]').forEach(function(s){var v=s.getAttribute('data-'+l.toLowerCase());if(v!=null)s.textContent=v;});}var cur='EN';try{cur=(localStorage.getItem('noor-lang')||'EN').toUpperCase();}catch(e){}if(cur==='FR')ap('FR');window.addEventListener('storage',function(e){if(e.key==='noor-lang')ap((e.newValue||'EN').toUpperCase());});document.addEventListener('click',function(e){if(e.target.closest('.lang,[data-nv-lang]')){setTimeout(function(){try{ap((localStorage.getItem('noor-lang')||'EN').toUpperCase());}catch(x){}},30);}});if('IntersectionObserver'in window){var io=new IntersectionObserver(function(en){en.forEach(function(x){if(x.isIntersecting){t.classList.add('in');io.disconnect();}});},{threshold:.15});io.observe(t);}else{t.classList.add('in');}})();</script></section>"
