              "settings": {
                "html": "<section class='nvds'><style>@import url('https://api.fontshare.com/v2/css?f[]=clash-display@500,600,700&f[]=satoshi@400,500,700&f[]=caveat-brush@400&display=swap');.nvds{--pk:#FF4FA3;--tl:#14B8A6;--cl:#FF8A5B;--yl:#FFCE4E;--cr:#FFF6EC;--ik:#0E1B2C;--fd:'Clash Display',system-ui,sans-serif;--fb:'Satoshi',system-ui,sans-serif;--fh:'Caveat Brush',cursive;--e:cubic-bezier(.2,.8,.2,1);font-family:var(--fb);color:var(--ik);background:var(--cr);padding:80px 0 0}.nvds *{box-sizing:border-box}.nvds a{text-decoration:none;color:inherit}.nvds .wrap{max-width:1280px;margin:0 auto;padding:0 32px}.nvds .head{display:flex;align-items:flex-end;justify-content:space-between;gap:30px;margin-bottom:42px}.nvds .ey{display:inline-flex;align-items:center;gap:8px;font-weight:700;font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--pk)}.nvds .ey::before{content:'';width:24px;height:2px;background:var(--pk)}.nvds h2{font-family:var(--fd);font-weight:600;font-size:clamp(40px,6vw,68px);letter-spacing:-.02em;line-height:.98;margin:16px 0 0}.nvds .hand{font-family:var(--fh);color:var(--pk);font-weight:400}.nvds .sub{font-size:18px;color:#0e1b2cbb;max-width:560px;margin-top:18px}.nvds .hint{font-family:var(--fh);font-size:22px;color:var(--tl);transform:rotate(-2deg);white-space:nowrap;padding-bottom:8px}.nvds .stage{overflow-x:auto;scrollbar-width:none;cursor:grab;scroll-snap-type:x proximity}.nvds .stage::-webkit-scrollbar{display:none}.nvds .stage.grab{cursor:grabbing}.nvds .track{display:flex;gap:28px;padding:10px 32px 72px;width:max-content}.nvds .card{position:relative;width:min(380px,80vw);flex:none;border:2px solid var(--ik);border-radius:22px;background:#fff;box-shadow:6px 6px 0 var(--ik);overflow:hidden;scroll-snap-align:start;transition:transform .35s var(--e),box-shadow .35s var(--e);opacity:0;transform:translateY(26px)}.nvds.in .card{opacity:1;transform:none}.nvds.in .card:nth-child(2){transition-delay:.05s}.nvds.in .card:nth-child(3){transition-delay:.1s}.nvds.in .card:nth-child(4){transition-delay:.15s}.nvds .card:hover{transform:translate(-4px,-6px);box-shadow:12px 12px 0 var(--ik)}.nvds .iw{position:relative;overflow:hidden;aspect-ratio:4/4.6;border-bottom:2px solid var(--ik)}.nvds .iw img{width:100%;height:100%;object-fit:cover;transform:scale(1.04);transition:transform .8s var(--e)}.nvds .card:hover .iw img{transform:scale(1.13) rotate(1.2deg)}.nvds .ptag{position:absolute;top:14px;left:14px;background:var(--yl);border:2px solid var(--ik);border-radius:999px;padding:7px 14px;font-family:var(--fd);font-weight:600;font-size:13.5px;box-shadow:3px 3px 0 var(--ik)}.nvds .num{position:absolute;top:10px;right:16px;z-index:2;font-family:var(--fd);font-weight:600;font-size:15px;color:#0e1b2c88;background:rgba(255,255,255,.82);border-radius:99px;padding:3px 10px}.nvds .body{padding:20px 22px 22px}.nvds .body h3{font-family:var(--fd);font-weight:600;font-size:26px}.nvds .body .tg{font-size:13.5px;color:#0e1b2c88;margin-top:5px}.nvds .panel{position:absolute;left:0;right:0;bottom:0;background:var(--ik);color:var(--cr);padding:22px;transform:translateY(101%);transition:transform .42s var(--e)}.nvds .card:hover .panel{transform:translateY(0)}.nvds .panel p{font-size:15px;line-height:1.5;color:#fff6ecd9}.nvds .go{display:inline-flex;align-items:center;gap:8px;margin-top:14px;font-family:var(--fd);font-weight:600;font-size:14.5px;color:var(--yl)}.nvds .go span{transition:transform .3s var(--e)}.nvds .card:hover .go span{transform:translateX(4px)}@media(max-width:720px){.nvds .head{flex-wrap:wrap}.nvds .hint{display:none}}@media(prefers-reduced-motion:reduce){.nvds .card{opacity:1!important;transform:none!important}}</style><div class='wrap'><div class='head'><div><span class='ey' data-en='Where we go' data-fr='Ou on va'>Where we go</span><h2><span data-en='Seven ways to ' data-fr='Sept facons de '>Seven ways to </span><span class='hand' data-en='wander.' data-fr='vagabonder.'>wander.</span></h2><p class='sub' data-en='Seven loose categories, endless itineraries. Tell us the vibe - we build the week.' data-fr='Sept categories souples, d infinies possibilites. Dites-nous l ambiance - on batit la semaine.'>Seven loose categories, endless itineraries. Tell us the vibe - we build the week.</p></div><span class='hint' data-en='drag or scroll →' data-fr='glissez ou defilez →'>drag or scroll →</span></div></div><div class='stage'><div class='track'><a class='card' href='/packages/'><span class='num'>01</span><div class='iw'><img src='https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-beach.jpg' alt='Beach'><span class='ptag'><span data-en='from $899' data-fr='des 899 $'>from $899</span></span></div><div class='body'><h3 data-en='Beach &amp; Tropics' data-fr='Plage &amp; Tropiques'>Beach &amp; Tropics</h3><div class='tg'>Cancun · Punta Cana · Varadero</div></div><div class='panel'><p data-en='All-inclusive sugar-sand weeks for when winter overstays its welcome.' data-fr='Semaines tout-inclus au sable sucre, quand l hiver s eternise.'>All-inclusive sugar-sand weeks for when winter overstays its welcome.</p><span class='go'><span data-en='See the trips' data-fr='Voir les voyages'>See the trips</span> →</span></div></a><a class='card' href='/packages/'><span class='num'>02</span><div class='iw'><img src='https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-mosque.jpg' alt='Hajj and Umrah'><span class='ptag'><span data-en='guided' data-fr='accompagne'>guided</span></span></div><div class='body'><h3 data-en='Hajj &amp; Umrah' data-fr='Hajj &amp; Omra'>Hajj &amp; Umrah</h3><div class='tg'>Makkah · Madinah</div></div><div class='panel'><p data-en='5-star proximity to the Haram, licensed mutawwif, full ziyarah program.' data-fr='Hotels 5* pres du Haram, mutawwif agree, programme ziyarah complet.'>5-star proximity to the Haram, licensed mutawwif, full ziyarah program.</p><span class='go'><span data-en='See the trips' data-fr='Voir les voyages'>See the trips</span> →</span></div></a><a class='card' href='/packages/'><span class='num'>03</span><div class='iw'><img src='https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-kasbah.jpg' alt='Morocco'><span class='ptag'><span data-en='from $1,740' data-fr='des 1 740 $'>from $1,740</span></span></div><div class='body'><h3 data-en='Morocco &amp; N. Africa' data-fr='Maroc &amp; Afrique du N.'>Morocco &amp; N. Africa</h3><div class='tg'>Marrakech · Fes · Chefchaouen</div></div><div class='panel'><p data-en='Souks, riads, and Saharan stargazing - small groups, local guides.' data-fr='Souks, riads, bivouacs dans le Sahara - petits groupes, guides locaux.'>Souks, riads, and Saharan stargazing - small groups, local guides.</p><span class='go'><span data-en='See the trips' data-fr='Voir les voyages'>See the trips</span> →</span></div></a><a class='card' href='/packages/'><span class='num'>04</span><div class='iw'><img src='https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-city.jpg' alt='European Cities'><span class='ptag'><span data-en='from $1,280' data-fr='des 1 280 $'>from $1,280</span></span></div><div class='body'><h3 data-en='European Cities' data-fr='Villes europeennes'>European Cities</h3><div class='tg'>Paris · Rome · Istanbul</div></div><div class='panel'><p data-en='Weekend escapes and slow 10-day loops through the old continent.' data-fr='Escapades de fin de semaine ou boucles lentes sur le vieux continent.'>Weekend escapes and slow 10-day loops through the old continent.</p><span class='go'><span data-en='See the trips' data-fr='Voir les voyages'>See the trips</span> →</span></div></a><a class='card' href='/packages/'><span class='num'>05</span><div class='iw'><img src='https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-villa.jpg' alt='Honeymoons'><span class='ptag'><span data-en='bespoke' data-fr='sur mesure'>bespoke</span></span></div><div class='body'><h3 data-en='Luxury Honeymoons' data-fr='Lunes de miel de luxe'>Luxury Honeymoons</h3><div class='tg'>Maldives · Santorini · Bora Bora</div></div><div class='panel'><p data-en='Overwater villas, private dinners, and absolutely no spreadsheet.' data-fr='Villas sur pilotis, diners prives, zero tableur.'>Overwater villas, private dinners, and absolutely no spreadsheet.</p><span class='go'><span data-en='See the trips' data-fr='Voir les voyages'>See the trips</span> →</span></div></a><a class='card' href='/packages/'><span class='num'>06</span><div class='iw'><img src='https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-bus.jpg' alt='Group Tours'><span class='ptag'><span data-en='from $2,190' data-fr='des 2 190 $'>from $2,190</span></span></div><div class='body'><h3 data-en='Group Tours' data-fr='Voyages de groupe'>Group Tours</h3><div class='tg'>Turquie · Japon · Egypte</div></div><div class='panel'><p data-en='Leave the planning to us. Bus, guide, 12 new friends, no stress.' data-fr='Laissez-nous la logistique. Autobus, guide, 12 nouveaux amis.'>Leave the planning to us. Bus, guide, 12 new friends, no stress.</p><span class='go'><span data-en='See the trips' data-fr='Voir les voyages'>See the trips</span> →</span></div></a><a class='card' href='/packages/'><span class='num'>07</span><div class='iw'><img src='https://wordpress-nginx-production-2777.up.railway.app/wp-content/uploads/2026/06/nv-torii.jpg' alt='Asia'><span class='ptag'><span data-en='from $1,990' data-fr='des 1 990 $'>from $1,990</span></span></div><div class='body'><h3 data-en='Asia' data-fr='Asie'>Asia</h3><div class='tg'>Bali · Thailande · Japon</div></div><div class='panel'><p data-en='Rice terraces, temple dawns, and noodles eaten standing up.' data-fr='Rizieres, temples a l aube, nouilles mangees debout.'>Rice terraces, temple dawns, and noodles eaten standing up.</p><span class='go'><span data-en='See the trips' data-fr='Voir les voyages'>See the trips</span> →</span></div></a></div></div><script>(function(){var d=document.querySelector('.nvds');if(!d)return;function ap(l){d.querySelectorAll('[data-en]').forEach(function(s){var v=s.getAttribute('data-'+l.toLowerCase());if(v!=null)s.textContent=v;});}var cur='EN';try{cur=(localStorage.getItem('noor-lang')||'EN').toUpperCase();}catch(e){}if(cur==='FR')ap('FR');window.addEventListener('storage',function(e){if(e.key==='noor-lang')ap((e.newValue||'EN').toUpperCase());});document.addEventListener('click',function(e){if(e.target.closest('.lang,[data-nv-lang]')){setTimeout(function(){try{ap((localStorage.getItem('noor-lang')||'EN').toUpperCase());}catch(x){}},30);}});var stage=d.querySelector('.stage');var down=false,sx=0,sl=0,moved=false;stage.addEventListener('pointerdown',function(e){down=true;moved=false;sx=e.clientX;sl=stage.scrollLeft;stage.classList.add('grab');});window.addEventListener('pointerup',function(){down=false;stage.classList.remove('grab');});stage.addEventListener('pointermove',function(e){if(!down)return;var dx=e.clientX-sx;if(Math.abs(dx)>5)moved=true;stage.scrollLeft=sl-dx;});stage.addEventListener('click',function(e){if(moved){e.preventDefault();}},true);if('IntersectionObserver'in window){var io=new IntersectionObserver(function(en){en.forEach(function(x){if(x.isIntersecting){d.classList.add('in');io.disconnect();}});},{threshold:.1});io.observe(d);}else{d.classList.add('in');}})();</script></section>"
              }
